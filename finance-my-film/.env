# Film Finance Finder - Environment Configuration

# Output file for notification log
OUTPUT_FILE=funding_opportunities.log

# Daily notes log (AI research + scan results)
DAILY_LOG=film_finance_daily.log

# ntfy push notifications (self-hosted)
# Set both to enable push notifications
NTFY_URL=https://notify.hello-server.me
NTFY_TOPIC=funding

# OpenCode AI model (leave empty for default free model)
# Available free models: opencode/glm-4.7-free, opencode/kimi-k2.5-free,
#   opencode/minimax-m2.1-free, opencode/trinity-large-preview-free
OPENCODE_MODEL=

# Database location
DATABASE_PATH=film_finance.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
