# Finance Film v2 - Environment Configuration
# Copy to .env and fill in your values

# ── Filmmaker Profile ─────────────────────────────────────────────────────

# Target funding amount in CAD
FILMMAKER__TARGET_AMOUNT_CAD=30000

# Geographic focus
FILMMAKER__LOCATION=Toronto, Ontario, Canada

# Target audience type
FILMMAKER__AUDIENCE=emerging_filmmakers

# Maximum project budget considered relevant
FILMMAKER__MAX_BUDGET_CAD=50000

# ── Notifications ──────────────────────────────────────────────────────────

# ntfy push notifications (optional - leave empty to disable)
# Set both URL and topic to enable push notifications
NOTIFICATIONS__NTFY_URL=
NOTIFICATIONS__NTFY_TOPIC=

# Log file for notifications
NOTIFICATIONS__FILE_LOG_PATH=funding_opportunities.log

# Send daily digest
NOTIFICATIONS__DAILY_DIGEST=true

# Digest time (HH:MM 24-hour format)
NOTIFICATIONS__DIGEST_TIME=09:00

# Maximum opportunities per digest
NOTIFICATIONS__MAX_OPPORTUNITIES_PER_DIGEST=15

# ── HTTP Client ───────────────────────────────────────────────────────────

# Request timeout in seconds
HTTP__TIMEOUT_SECONDS=15

# Maximum retry attempts
HTTP__MAX_RETRIES=3

# Exponential backoff factor
HTTP__RETRY_BACKOFF_FACTOR=2.0

# Delay between requests to same host
HTTP__RATE_LIMIT_DELAY=1.0

# Maximum concurrent requests
HTTP__MAX_CONCURRENT=5

# ── AI Provider (Optional) ────────────────────────────────────────────────

# Enable AI-powered research
AI__ENABLED=false

# AI provider (currently only "opencode" supported)
AI__PROVIDER=opencode

# Model identifier (leave empty for default)
AI__MODEL=

# AI request timeout in seconds
AI__TIMEOUT_SECONDS=120

# ── Database ──────────────────────────────────────────────────────────────

# SQLite database path
DATABASE__PATH=film_finance.db

# Echo SQL statements (debug)
DATABASE__ECHO_SQL=false

# ── Logging ───────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOGGING__LEVEL=INFO

# Log file path
LOGGING__FILE_PATH=film_finance.log

# Use JSON log format
LOGGING__JSON_FORMAT=false
